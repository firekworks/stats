{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": null,
  "crons": [
    {
      "path": "/api/cron/meta-ads-sync",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/meta-social-sync",
      "schedule": "30 7 * * *"
    },
    {
      "path": "/api/cron/google-business-sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/whatsapp-sync",
      "schedule": "0 9 * * *"
    }
  ]
}
